{
  "name": "keepalived-tools",
  "displayName": "Keepalived Configuration Tools",
  "description": "Syntax highlighting, validation, completion, hover, snippets and formatting for keepalived.conf",
  "version": "1.0.0",
  "license": "GPL-2.0-or-later",
  "publisher": "keepalived-tools",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#185663",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jin7942/keepalived-tools.git"
  },
  "bugs": {
    "url": "https://github.com/jin7942/keepalived-tools/issues"
  },
  "homepage": "https://github.com/jin7942/keepalived-tools#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onLanguage:keepalived"
  ],
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "keepalived",
    "vrrp",
    "lvs",
    "ipvs",
    "high-availability"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "keepalived",
        "aliases": [
          "keepalived",
          "Keepalived"
        ],
        "filenames": [
          "keepalived.conf"
        ],
        "filenamePatterns": [
          "**/keepalived/*.conf",
          "**/keepalived.conf.d/**/*.conf",
          "**/conf.d/*.conf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "keepalived",
        "scopeName": "source.keepalived",
        "path": "./syntaxes/keepalived.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "keepalived",
        "path": "./snippets/keepalived.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "keepalived.showSchemaVersion",
        "title": "Show Schema Version",
        "category": "Keepalived"
      },
      {
        "command": "keepalived.validateActiveFile",
        "title": "Validate Active File",
        "category": "Keepalived"
      },
      {
        "command": "keepalived.formatDocument",
        "title": "Format Document",
        "category": "Keepalived"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "keepalived.validateActiveFile",
          "when": "editorLangId == keepalived"
        },
        {
          "command": "keepalived.formatDocument",
          "when": "editorLangId == keepalived"
        }
      ]
    },
    "configuration": {
      "title": "Keepalived",
      "properties": {
        "keepalived.validation.enable": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable diagnostics (syntax, type, semantic, include) for `keepalived.conf` files."
        },
        "keepalived.validation.reportMissingRequired": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Report missing required directives (e.g. `script` in a `vrrp_script` block). Off by default to avoid false positives while editing (ADR-0011)."
        },
        "keepalived.validation.reportUnused": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Report defined-but-unreferenced symbols (e.g. an unused `vrrp_script`). Off by default — an unreferenced definition is valid keepalived (ADR-0011)."
        },
        "keepalived.validation.maxFileSize": {
          "type": "number",
          "default": 1048576,
          "markdownDescription": "Skip validation for files larger than this many bytes, to keep the editor responsive on very large generated configs. Set to `0` to disable the limit."
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:schema": "tsx tools/extract-schema/merge-overrides.ts",
    "build:grammar": "tsx tools/extract-schema/gen-grammar.ts",
    "build": "npm run build:schema && npm run build:grammar && tsc --noEmit && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "npm run build:schema && tsx --test test/**/*.test.ts",
    "package": "npm run build && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
