{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "keepalived",
  "scopeName": "source.keepalived",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#conditional"
    },
    {
      "include": "#blocks"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sequence"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#ipcidr"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#booleans"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.keepalived",
          "match": "#.*$"
        },
        {
          "name": "comment.line.exclamation.keepalived",
          "match": "!.*$"
        }
      ]
    },
    "conditional": {
      "match": "^\\s*(@\\^?[\\w-]+)",
      "captures": {
        "1": {
          "name": "keyword.control.conditional.keepalived"
        }
      }
    },
    "blocks": {
      "name": "keyword.control.block.keepalived",
      "match": "\\b(virtual_ipaddress_excluded|virtual_server_group|notification_email|vrrp_track_process|virtual_ipaddress|static_ipaddress|track_interface|vrrp_sync_group|vrrp_track_file|authentication|virtual_routes|virtual_server|vrrp_instance|virtual_rules|static_routes|track_script|static_rules|unicast_peer|bfd_instance|global_defs|vrrp_script|real_server|track_group|MISC_CHECK|track_file|SMTP_CHECK|PING_CHECK|FILE_CHECK|garp_group|TCP_CHECK|auth_hmac|DNS_CHECK|UDP_CHECK|BFD_CHECK|HTTP_GET|SSL_GET|host|url)\\b"
    },
    "directives": {
      "name": "keyword.other.directive.keepalived",
      "match": "\\b(vrrp_netlink_monitor_rcv_bufs_force|lvs_netlink_monitor_rcv_bufs_force|fifo_write_vrrp_states_on_reload|vrrp_garp_master_refresh_repeat|vrrp_netlink_cmd_rcv_bufs_force|lvs_netlink_cmd_rcv_bufs_force|process_monitor_rcv_bufs_force|snmp_rs_stats_update_interval|snmp_vs_stats_update_interval|vrrp_netlink_monitor_rcv_bufs|lvs_netlink_monitor_rcv_bufs|vrrp_higher_prio_send_advert|vrrp_notify_priority_changes|vrrp_garp_lower_prio_repeat|nftables_ipvs_start_fwmark|vrrp_garp_lower_prio_delay|garp_master_refresh_repeat|sync_group_tracking_weight|vrrp_lower_prio_no_advert|vrrp_netlink_cmd_rcv_bufs|vrrp_owner_ignore_adverts|lvs_sync_daemon_interface|checker_log_all_failures|lvs_netlink_cmd_rcv_bufs|process_monitor_rcv_bufs|vrrp_garp_master_refresh|vrrp_skip_check_adv_addr|notification_email_from|vrrp_garp_master_repeat|min_auto_priority_delay|shutdown_script_timeout|vrrp_down_timer_adverts|vrrp_rx_bufs_multiplier|higher_prio_send_advert|notify_priority_changes|persistence_granularity|sorry_server_lvs_method|vrrp_garp_master_delay|enable_script_security|dbus_no_interface_name|enable_snmp_keepalived|nftables_ipvs_priority|startup_script_timeout|vrrp_check_unicast_src|garp_lower_prio_repeat|checker_rlimit_rttime|vrrp_delay_after_boot|garp_lower_prio_delay|unicast_fault_no_peer|smtp_connect_timeout|checker_cpu_affinity|checker_process_name|checker_rlimit_rtime|tmp_config_directory|vrrp_vmac_garp_intvl|lower_prio_no_advert|no_virtual_ipaddress|old_unicast_checksum|sorry_server_inhibit|checker_rt_priority|enable_snmp_checker|reload_check_config|vrrp_rx_bufs_policy|garp_master_refresh|promote_secondaries|skip_check_adv_addr|persistence_timeout|disable_local_igmp|dynamic_interfaces|smtp_alert_checker|vrrp_garp_extra_if|vrrp_garp_interval|vrrp_rlimit_rttime|vrrp_startup_delay|dont_track_primary|down_timer_adverts|garp_master_repeat|kernel_rx_buf_size|persistence_engine|delay_before_retry|inhibit_on_failure|max_auto_priority|bfd_rlimit_rttime|data_use_instance|dbus_service_name|default_interface|enable_snmp_rfcv2|enable_snmp_rfcv3|log_unknown_vrids|lvs_flush_on_stop|nftables_counters|nftables_priority|no_checker_emails|use_symlink_paths|v3_checksum_as_v2|vrrp_cpu_affinity|vrrp_gna_interval|vrrp_mcast_group4|vrrp_mcast_group6|vrrp_process_name|vrrp_rlimit_rtime|virtual_router_id|advertisement_int|check_unicast_src|garp_master_delay|bfd_cpu_affinity|bfd_process_name|bfd_rlimit_rtime|checker_priority|enable_snmp_vrrp|lvs_flush_onstop|lvs_process_name|nftables_ifindex|reload_time_file|rs_init_notifies|vmac_addr_prefix|vrrp_notify_fifo|vrrp_rt_priority|log_all_failures|regex_min_offset|regex_max_offset|min_reply_length|max_reply_length|bfd_rt_priority|checker_no_swap|config_save_dir|enable_snmp_rfc|iproute_etc_dir|iproute_usr_dir|lvs_notify_fifo|lvs_sync_daemon|no_email_faults|smtp_alert_vrrp|state_dump_file|stats_dump_file|vmac_garp_intvl|global_tracking|connect_timeout|terminate_delay|json_dump_file|smtp_helo_name|unicast_src_ip|vmac_xmit_base|notify_deleted|regex_no_match|include_check|nftables_ipvs|process_names|reload_repeat|vrrp_iptables|vrrp_min_garp|vrrp_priority|preempt_delay|notify_master|notify_backup|garp_extra_if|garp_interval|track_process|use_vmac_addr|http_protocol|fast_recovery|tls_compliant|regex_options|require_reply|bfd_priority|enable_traps|json_version|lvs_timeouts|process_name|vrrp_no_swap|vrrp_version|notify_fault|mcast_dst_ip|mcast_src_ip|track_src_ip|sorry_server|connect_port|nb_get_retry|misc_timeout|misc_dynamic|full_command|gna_interval|smtp_server|script_user|bfd_no_swap|enable_dbus|notify_fifo|random_seed|reload_file|snmp_socket|vmac_prefix|vrrp_ipsets|vrrp_strict|native_ipv6|strict_mode|unicast_ttl|notify_stop|virtualhost|mh-fallback|sh-fallback|notify_down|status_code|regex_stack|time_window|anti_replay|param_match|neighbor_ip|smtp_alert|advert_int|use_ipvlan|lvs_method|delay_loop|ha_suspend|hysteresis|quorum_max|uthreshold|lthreshold|connect_ip|enable_sni|active_key|fork_delay|interfaces|multiplier|router_id|lvs_flush|interface|nopreempt|no_accept|track_bfd|auth_type|auth_pass|init_fail|lvs_sched|ip_family|snmp_name|notify_up|bind_port|misc_path|helo_name|source_ip|nftables|priority|use_vmac|interval|protocol|max_hops|preempt|version|timeout|lb_algo|lb_kind|mh-port|sh-port|bind_if|payload|process|idle_tx|passive|accept|notify|script|weight|quorum|warmup|hashed|flag-1|flag-2|flag-3|bindto|fwmark|digest|min_rx|min_tx|umask|state|debug|group|alpha|omega|retry|regex|delay|rise|fall|user|path|file|mode|type|name|vrf|ops|key|ttl)\\b"
    },
    "strings": {
      "name": "string.quoted.double.keepalived",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.keepalived",
          "match": "\\\\."
        }
      ]
    },
    "variables": {
      "name": "variable.other.keepalived",
      "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
    },
    "sequence": {
      "name": "support.function.sequence.keepalived",
      "match": "~[A-Za-z_][\\w]*\\([^)]*\\)"
    },
    "ipcidr": {
      "patterns": [
        {
          "name": "constant.numeric.ip.keepalived",
          "match": "\\b(?:(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)\\.){3}(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)(?:/\\d{1,2})?\\b"
        },
        {
          "name": "constant.numeric.ip.keepalived",
          "match": "(?<![\\w:])(?:[0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f]{0,4}(?:/\\d{1,3})?"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.keepalived",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "booleans": {
      "name": "constant.language.boolean.keepalived",
      "match": "\\b(?:true|false|on|off|yes|no)\\b"
    }
  }
}
